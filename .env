# ====================================================
# This file contains environment variables such as API Keys for the project.
# --- Cognee Cloud ---
COGNEE_SERVICE_URL=your-cognee-cloud-base-service-url-that-starts-with-https://tenant-and-ends-with-aws.cognee.ai
COGNEE_API_KEY=your-cognee-cloud-api-key-which-you-have-created-in-the-cognee-cloud-portal

# --- OpenRouter (LLM) ---
OPENROUTER_API_KEY=your-openrouter-api-key

# --- Google AI Studio ---
GOOGLE_API_KEY=google-aistudio-api-key-its-optional-if-you-want-to-use-google-aistudio-llm

# --- Cognee Local Storage Paths (writable project directories) ---
# These redirect Cognee's local SQLite/cache away from the read-only
# Python installation folder into our project's Backend directory.
# SYSTEM_ROOT_DIRECTORY=c:\MY-SPACE\LoreBuilderCogneeProject\Backend\cognee_system
# DATA_ROOT_DIRECTORY=c:\MY-SPACE\LoreBuilderCogneeProject\Backend\cognee_data

